{
  "name": "gss-hms-v2",
  "private": true,
  "version": "2.0.0",
  "description": "Gandhi Seva Sadan Hospital Management System - Standalone Desktop + LAN",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "server:build": "npx esbuild src-server/index.ts --bundle --platform=node --outfile=dist-server/index.cjs --external:better-sqlite3 --format=cjs",
    "build:all": "npm run build && npm run server:build",
    "preview": "vite preview",
    "server:dev": "tsx watch src-server/index.ts",
    "dev:all": "concurrently -n ui,api -c cyan,green \"npm run dev\" \"npm run server:dev\"",
    "db:seed": "tsx src-server/db/seed.ts"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.7.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^3.7.0",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.27.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  }
}
